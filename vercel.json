{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/products/:path*",
      "destination": "/products/:path*"
    },
    {
      "source": "/videos/:path*",
      "destination": "/videos/:path*"
    },
    {
      "source": "/((?!api|assets|products|videos).*)",
      "destination": "/index.html"
    }
  ]
}
